{
  "name": "FastR",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "clean-gradle": "cd android && .\\gradlew.bat clean",
    "assemble-debug": "cd android && .\\gradlew.bat assembleDebug",
    "assemble-release": "cd android && .\\gradlew.bat assembleRelease",
    "bundle-release": "cd android && .\\gradlew.bat bundleRelease",
    "install-release": "cd android && .\\gradlew.bat installRelease",
    "sign-release": "keytool -genkeypair -v -storetype PKCS12 -keystore android/app/fastr-prod.keystore -alias fastr-prod -keyalg RSA -keysize 2048 -validity 10000"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.10.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "^19.2.0",
    "eslint": "^8.19.0",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
